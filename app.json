{
  "expo": {
    "name": "HyperChat AI",
    "slug": "HyperChatAI",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hyperchat.ai"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.hyperchat.ai",
      "predictiveBackGestureEnabled": false,
      "versionCode": 1,
      "minSdkVersion": 31,
      "targetSdkVersion": 34,
      "compileSdkVersion": 35
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow HyperChat AI to access your camera to capture photos and analyze images."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow HyperChat AI to access your photos to analyze images."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow HyperChat AI to access your location for sharing in chats."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow HyperChat AI to access your microphone for voice messages."
        }
      ]
    ],
    "permissions": [
      "CAMERA",
      "READ_EXTERNAL_STORAGE",
      "WRITE_EXTERNAL_STORAGE",
      "RECORD_AUDIO",
      "ACCESS_FINE_LOCATION",
      "ACCESS_COARSE_LOCATION"
    ],
    "extra": {
      "openaiApiKey": ""
    }
  }
}
